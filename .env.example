# BTC-BOT Environment Configuration Example
# Copy to .env and fill in your values.
# Never commit .env to git.

# ── Binance API ──────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ── Bot Mode ─────────────────────────────────────────────────────────────────
# PAPER = paper trading (no real funds)
# LIVE  = live trading (real funds)
BOT_MODE=PAPER

# ── Telegram Alerts (optional) ───────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Proxy / Egress Configuration ─────────────────────────────────────────────
# Required when server IP is blocked by Binance CloudFront.
# See docs/infra/egress-vultr.md for setup instructions.
#
# SOCKS5 exit node (recommended):
# PROXY_ENABLED=true
# PROXY_URL=<vultr-ip>:1080
# PROXY_TYPE=socks5
# PROXY_STICKY_MINUTES=60
# PROXY_FAILOVER_LIST=
#
# HTTP proxy (alternative):
# PROXY_ENABLED=true
# PROXY_URL=<proxy-host>:<port>
# PROXY_TYPE=http
# PROXY_STICKY_MINUTES=30
# PROXY_FAILOVER_LIST=<backup-host>:<port>,<backup2-host>:<port>
#
PROXY_ENABLED=false
PROXY_URL=
PROXY_TYPE=socks5
PROXY_STICKY_MINUTES=60
PROXY_FAILOVER_LIST=
