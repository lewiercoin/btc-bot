[Unit]
Description=BTC Bot Daily Data Collector (DXY + ETF)
After=network-online.target

[Service]
Type=oneshot
User=btc-bot
WorkingDirectory=/home/btc-bot/btc-bot
EnvironmentFile=/home/btc-bot/btc-bot/.env
ExecStart=/home/btc-bot/btc-bot/.venv/bin/python \
    scripts/server/run_daily_data_collector.py
StandardOutput=journal
StandardError=journal
